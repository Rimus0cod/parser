# ---------------------------------------------------------------------------
# Core app
# ---------------------------------------------------------------------------
APP_NAME=Real Estate SaaS Core
APP_ENV=prod
APP_DEBUG=false

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_DATABASE=imoti
MYSQL_ROOT_PASSWORD=change_me_root_password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# Voice / Twilio
# ---------------------------------------------------------------------------
VOICE_ENABLED=false
VOICE_PUBLIC_BASE_URL=
VOICE_WS_PUBLIC_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE=true
GOOGLE_APPLICATION_CREDENTIALS=./google.json

# ---------------------------------------------------------------------------
# Scraper runtime
# ---------------------------------------------------------------------------
SCRAPE_TIMEOUT_SECONDS=30
SCRAPE_INTERVAL_SECONDS=900
SCRAPE_CONCURRENCY=8
SCRAPE_RETRY_COUNT=3
SCRAPE_BACKOFF_BASE_SECONDS=1.5
SCRAPE_BACKOFF_CAP_SECONDS=12
SCRAPE_DELAY_MIN_SECONDS=0.15
SCRAPE_DELAY_MAX_SECONDS=0.80
SCRAPE_FOLLOW_REDIRECTS=true
SCRAPE_VERIFY_SSL=true
SCRAPE_DETAIL_PAGES=true
HTTP_MAX_CONNECTIONS=30
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
CITY_FILTER=

# Optional custom site config as JSON array.
# If empty, built-in sites are used:
# imoti.bg, alo.bg, dom.ria.com, olx.ua, lun.ua
SCRAPER_SITES=

# ---------------------------------------------------------------------------
# Proxy rotation
# ---------------------------------------------------------------------------
PROXY_ENABLED=false
PROXY_LIST=
PROXY_ROTATION_STRATEGY=random
PROXY_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Logging and observability
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=logs
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Streamlit auth
# ---------------------------------------------------------------------------
STREAMLIT_COOKIE_NAME=lead_scanner_cookie
STREAMLIT_COOKIE_KEY=change_me_cookie_key_please
STREAMLIT_COOKIE_EXPIRY_DAYS=7
STREAMLIT_JWT_SECRET=change_me_jwt_secret_32chars_min
STREAMLIT_USERS_YAML_PATH=app/ui/users.yaml

# ---------------------------------------------------------------------------
# Scheduler compatibility
# ---------------------------------------------------------------------------
SCHEDULER_ENABLED=false
SCHEDULER_CRON=*/15 * * * *
SCHEDULER_TIMEZONE=Europe/Kyiv

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOKS_ENABLED=false
WEBHOOKS_URLS=

# ---------------------------------------------------------------------------
# AmoCRM
# ---------------------------------------------------------------------------
AMOCRM_ENABLED=false
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
AMOCRM_REFRESH_TOKEN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=

# ---------------------------------------------------------------------------
# Bitrix24
# ---------------------------------------------------------------------------
BITRIX24_ENABLED=false
BITRIX24_WEBHOOK_URL=
BITRIX24_DOMAIN=
BITRIX24_CLIENT_ID=
BITRIX24_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Legacy compatibility
# ---------------------------------------------------------------------------
GOOGLE_SHEET_ID=
SERVICE_ACCOUNT_JSON=./google.json
SHEET_NAME=Imoti_BG_Rentals
EMAIL_FROM=
EMAIL_TO=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAX_PAGES=26
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
LOG_FILE=./parser.log
AGENCIES_CSV_PATH=./agencies.csv
MYSQL_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_HISTORY_CHUNK_SIZE=20
TELEGRAM_DEFAULT_HISTORY_DAYS=7
TELEGRAM_STARTUP_PREVIEW_COUNT=3
