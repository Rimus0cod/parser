APP_NAME=Real Estate SaaS Core
APP_ENV=dev
APP_DEBUG=false

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_DATABASE=imoti
MYSQL_ROOT_PASSWORD=change_me_root_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=logs

STREAMLIT_COOKIE_NAME=lead_scanner_cookie
STREAMLIT_COOKIE_KEY=change_me_cookie_key_please
STREAMLIT_COOKIE_EXPIRY_DAYS=7
STREAMLIT_JWT_SECRET=change_me_jwt_secret_32chars_min
STREAMLIT_USERS_YAML_PATH=app/ui/users.yaml

SCRAPE_TIMEOUT_SECONDS=30
SCRAPE_INTERVAL_SECONDS=900
SCRAPE_CONCURRENCY=8
SCRAPE_RETRY_COUNT=3
SCRAPE_BACKOFF_BASE_SECONDS=1.5
SCRAPE_BACKOFF_CAP_SECONDS=12.0
SCRAPE_DELAY_MIN_SECONDS=0.15
SCRAPE_DELAY_MAX_SECONDS=0.8
SCRAPE_FOLLOW_REDIRECTS=true
SCRAPE_VERIFY_SSL=true
SCRAPE_DETAIL_PAGES=true
HTTP_MAX_CONNECTIONS=30
HTTP_MAX_KEEPALIVE_CONNECTIONS=10

SCRAPLING_DYNAMIC_ENABLED=false
SCRAPLING_STEALTH_ENABLED=false
SCRAPLING_DYNAMIC_CONCURRENCY=2
SCRAPLING_STEALTH_CONCURRENCY=1
SCRAPLING_HTTP_IMPERSONATE=chrome
SCRAPLING_HTTP3=true
SCRAPLING_DISABLE_RESOURCES=true
SCRAPLING_DISABLE_ADS=true
SCRAPLING_BLOCK_WEBRTC=true
SCRAPLING_NETWORK_IDLE=true
SCRAPLING_SOLVE_CLOUDFLARE=true
SCRAPLING_STEALTH_HUMANIZE=true
SCRAPLING_WAIT_SELECTOR_TIMEOUT_MS=12000
SCRAPLING_BLOCKED_MARKERS=["access denied","captcha","cloudflare","turnstile","just a moment","verify you are human"]
SCRAPLING_STORAGE_TABLE=scrapling_adaptive_elements

PROXY_ENABLED=false
PROXY_LIST=
PROXY_ROTATION_STRATEGY=random
PROXY_MAX_RETRIES=3

SCRAPER_SITES=
CITY_FILTER=

WEBHOOKS_ENABLED=false
WEBHOOKS_URLS=

AMOCRM_ENABLED=false
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
AMOCRM_REFRESH_TOKEN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=

BITRIX24_ENABLED=false
BITRIX24_WEBHOOK_URL=
BITRIX24_DOMAIN=
BITRIX24_CLIENT_ID=
BITRIX24_CLIENT_SECRET=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

VOICE_ENABLED=false
VOICE_PUBLIC_BASE_URL=
VOICE_WS_PUBLIC_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE=true
GOOGLE_APPLICATION_CREDENTIALS=
