# =============================================================================
# .env.example — Configuration template for the imoti.bg rental scraper
#
# Instructions:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below (especially GOOGLE_SHEET_ID and
#      SERVICE_ACCOUNT_JSON — those are required).
#   3. Never commit .env to version control!  Add it to .gitignore.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Google Sheets
# ─────────────────────────────────────────────────────────────────────────────

# The long ID taken from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Absolute (or relative) path to your service-account JSON key file.
# Example (Linux/macOS):  /home/youruser/secrets/imoti-bot-sa.json
# Example (Windows):      C:\Users\YourName\secrets\imoti-bot-sa.json
SERVICE_ACCOUNT_JSON=/path/to/service-account.json


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Google Sheets
# ─────────────────────────────────────────────────────────────────────────────

# Name of the Google Spreadsheet (must match the actual file name exactly).
# Default: Imoti_BG_Rentals
SHEET_NAME=Imoti_BG_Rentals


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Email notifications (SMTP)
# Leave blank to disable email sending.
# ─────────────────────────────────────────────────────────────────────────────

# The "From" address shown in the email header.
EMAIL_FROM=your.email@gmail.com

# Recipient address(es).  Multiple recipients: comma-separated.
#   EMAIL_TO=first@example.com,second@example.com
EMAIL_TO=recipient@example.com

# SMTP server hostname.  Default: smtp.gmail.com
SMTP_SERVER=smtp.gmail.com

# SMTP port.  587 = TLS (STARTTLS).  Default: 587
SMTP_PORT=587

# SMTP login username (usually the same as EMAIL_FROM for Gmail).
SMTP_USER=your.email@gmail.com

# SMTP password.  For Gmail, use a 16-character App Password — NOT your Google
# account password.  Generate one at:
#   https://myaccount.google.com/apppasswords
# Example (with spaces as displayed by Google):
#   SMTP_PASSWORD=abcd efgh ijkl mnop
SMTP_PASSWORD=your_app_password_here


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Scraper behaviour
# ─────────────────────────────────────────────────────────────────────────────

# Maximum number of rental listing pages to scrape.  Real site has ~26 pages.
# Default: 30
MAX_PAGES=30

# Maximum number of agency directory pages to scrape (used with --update-agencies).
# Real site has ~13 pages.  Default: 15
MAX_AGENCY_PAGES=15

# Minimum and maximum seconds to wait between HTTP requests.
# Increase these if you receive 429 / 503 errors from the server.
# Default: 2.0 / 5.0
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0

# Optional city filter.  If set, only listings whose location contains this
# string (case-insensitive) are kept.  Leave blank to collect all cities.
# Example: CITY_FILTER=София
CITY_FILTER=


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Logging
# ─────────────────────────────────────────────────────────────────────────────

# Log level.  One of: DEBUG, INFO, WARNING, ERROR.  Default: INFO
LOG_LEVEL=INFO

# Optional path to write logs to a file (in addition to stdout).
# Leave blank for console-only logging.
# Example: LOG_FILE=/var/log/imoti_scraper.log
LOG_FILE=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — CSV Export
# ─────────────────────────────────────────────────────────────────────────────

# Optional path to export agencies to CSV file.
# If set, agencies will be exported to this path when running --update-agencies.
# The CSV will contain columns: Agency Name, Phone Number, City
# Example: AGENCIES_CSV_PATH=agencies.csv
AGENCIES_CSV_PATH=agencies.csv