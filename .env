# =============================================================================
# .env.example — Copy this to .env and fill in your own values.
# NEVER commit the real .env file to version control!
# =============================================================================

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID found in your spreadsheet's URL:
#   https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=1IHlQUDODPGJnDwC9Qz1MYPMo2fryHE5W0BK9svy9c6U

# Absolute or relative path to your Google Service Account JSON credentials.
# See README.md for how to create this file.
SERVICE_ACCOUNT_JSON=/home/diff/Desktop/parser/google.json

# Human-readable name of the Google Spreadsheet file (must match exactly).
SHEET_NAME=Imoti_BG_Rentals

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Sender address (your Gmail address when using Gmail + App Password).
EMAIL_FROM=macxi3333@gmail.com

# Recipient(s). Use a comma-separated list for multiple recipients.
EMAIL_TO=macxi6666@gmail.com

# SMTP settings — defaults below work for Gmail with TLS.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (same as EMAIL_FROM when using Gmail).
SMTP_USER=macxi3333@gmail.com

# Your Gmail App Password (16 characters, no spaces).
# See README.md → "How to get Gmail App Password".
SMTP_PASSWORD=wmwz smpv unii vvky

# ── Scraper behaviour ─────────────────────────────────────────────────────────
# Maximum number of listing pages to scrape (real site has ~26).
MAX_PAGES=26

# Polite delay between HTTP requests, in seconds (random value in this range).
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0

# Optional: only keep apartments in this city (case-insensitive substring match).
# Leave blank to collect from all cities.
# Example: CITY_FILTER=София
CITY_FILTER=

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional path to a log file (leave blank to log to console only).
# LOG_FILE=/var/log/imoti_scraper.log
LOG_FILE=/home/diff/parser.log